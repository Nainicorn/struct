{{#if main}}
<div class="__renderbox-container">
    <!-- IFC Viewer (hidden until render selected) -->
    <div class="__renderbox-viewer">
        <div class="__renderbox-loading">
            <span>Loading IFC model...</span>
        </div>
    </div>

    <!-- Main Content Area: Message + Chat -->
    <div class="__renderbox-content">
        <!-- Welcome Message -->
        <div class="__renderbox-message">
            <p class="__renderbox-message-text">What do you want to render today?</p>
        </div>

        <!-- File Preview (shown when files are staged) -->
        <div class="__renderbox-file-preview" style="display: none;">
            <div class="__renderbox-file-preview-header">
                <h3>Attached Files</h3>
            </div>
            <div class="__renderbox-file-list"></div>
        </div>

        <!-- Render Metadata (shown when viewing render) -->
        <div class="__renderbox-metadata">
            <div class="__renderbox-metadata-header">
                <div>
                    <h3 class="__renderbox-metadata-title"></h3>
                    <p class="__renderbox-metadata-description"></p>
                </div>
                <div class="__renderbox-metadata-actions">
                    <button class="__renderbox-metadata-download" title="Download IFC file" style="display: none;">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 18px; height: 18px;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                        </svg>
                    </button>
                    <button class="__renderbox-metadata-delete" title="Delete render">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 18px; height: 18px;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="__renderbox-metadata-files">
                <h4>Source Files</h4>
                <div class="__renderbox-metadata-file-list"></div>
            </div>
        </div>
    </div>

    <!-- Chat Footer (always visible) -->
    <div class="__renderbox-footer">
        <div class="__renderbox-chat">
            <div class="__renderbox-chat-input">
                <input
                    type="file"
                    multiple
                    id="__renderbox-file-input"
                    style="display: none"
                    class="__renderbox-file-input"
                />
                <button class="__renderbox-attach" title="Attach files">
                    <svg class="__renderbox-action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.414a6 6 0 108.486 8.486L20.5 13"></path>
                    </svg>
                </button>
                <textarea
                    placeholder="Describe what you want to render..."
                    class="__renderbox-input __renderbox-description"
                    rows="3"
                ></textarea>
                <div class="__renderbox-chat-actions">
                    <button class="__renderbox-send __renderbox-start" title="Start rendering">
                        <svg class="__renderbox-action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{{/if}}
