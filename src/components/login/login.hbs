{{#if main}}
<div class="__login-container">
    <div class="__login-header">
        <div class="__login-branding">
            <span class="__brand-name">BUILTING</span>
        </div>
    </div>

    <div class="__login-main">
        <div class="__login-body">
            <div class="__login-title">Sign In</div>
            <form id="login-form" class="__login-form">
                <input
                    type="email"
                    id="email"
                    class="__login-input"
                    placeholder="Enter your email address"
                    required
                    aria-label="Email address"
                />
                <input
                    type="password"
                    id="password"
                    class="__login-input"
                    placeholder="Enter your password"
                    required
                    aria-label="Password"
                />
                <button type="submit" id="submit" class="__login-button" aria-label="Submit">
                    Sign In
                    <svg class="__login-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                    </svg>
                </button>
            </form>
            <div class="__error-message" id="error-message"></div>
        </div>
    </div>

    <div class="__login-footer">
        <div class="__login-credit">
            <span>Powered by BUILTING AI</span>
        </div>
    </div>
</div>
{{/if}}
