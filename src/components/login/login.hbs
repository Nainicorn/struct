<div class="login-container">
    <div class="login-header">
        <svg class="logo-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
            <polyline points="17 21 17 13 7 13 7 21"></polyline>
            <polyline points="7 5 7 13 17 13 17 5"></polyline>
        </svg>
        <div class="logo-text">BUILTING</div>
    </div>

    <div class="login-content">
        <div class="login-card">
            <h1 class="login-heading">Get Started</h1>
            <form id="login-form" class="login-form">
                <input
                    type="email"
                    id="email"
                    class="email-input"
                    placeholder="enter email"
                    required
                    aria-label="Email address"
                />
                <button type="submit" id="submit" class="submit-btn" aria-label="Submit">
                    <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                    </svg>
                </button>
            </form>
            <div class="error-message" id="error-message"></div>
        </div>
    </div>
</div>
