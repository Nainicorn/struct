{
  "name": "builting-bedrock-ifc",
  "version": "1.0.0",
  "type": "module",
  "description": "Bedrock IFC extraction Lambda — VentSim, DXF, XLSX/DOCX parsers + multi-pass Bedrock",
  "main": "index.mjs",
  "scripts": {
    "test": "vitest run",
    "build": "esbuild index.mjs --bundle --minify --platform=node --target=node20 --outfile=dist/index.mjs --format=esm --external:@aws-sdk/* --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\""
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.989.0",
    "@aws-sdk/client-s3": "^3.989.0",
    "@fast-csv/parse": "^5.0.2",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "mammoth": "^1.8.0",
    "dxf-parser": "^1.1.2"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "esbuild": "^0.24.0"
  }
}
