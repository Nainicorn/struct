{
  "Comment": "Pipeline: Read → Extract → Resolve → TopologyEngine (structure+geometry+validate) → Generate → Store → SeedSensors. Catch-all error handler writes 'failed' status to DynamoDB. SeedSensors is non-critical (failure doesn't affect render).",
  "StartAt": "ReadRenderMetadata",
  "States": {
    "ReadRenderMetadata": {
      "Type": "Task",
      "Resource": "arn:aws-us-gov:lambda:us-gov-east-1:008368474482:function:builting-read",
      "ResultPath": "$.metadata",
      "Next": "ExtractBuildingSpec",
      "Retry": [{ "ErrorEquals": ["States.ALL"], "IntervalSeconds": 2, "MaxAttempts": 2, "BackoffRate": 2, "MaxDelaySeconds": 30, "JitterStrategy": "FULL" }],
      "Catch": [{ "ErrorEquals": ["States.ALL"], "ResultPath": "$.error", "Next": "HandleFailure" }]
    },

    "ExtractBuildingSpec": {
      "Type": "Task",
      "Resource": "arn:aws-us-gov:lambda:us-gov-east-1:008368474482:function:builting-extract",
      "Parameters": {
        "renderId.$": "$.renderId",
        "userId.$": "$.userId",
        "bucket.$": "$.bucket",
        "files.$": "$.metadata.files",
        "description.$": "$.metadata.render.description",
        "render.$": "$.metadata.render",
        "renderRevision.$": "$.metadata.render.render_revision"
      },
      "ResultPath": "$.specResult",
      "Next": "ResolveClaims",
      "Retry": [{ "ErrorEquals": ["States.ALL"], "IntervalSeconds": 5, "MaxAttempts": 2, "BackoffRate": 2, "MaxDelaySeconds": 60, "JitterStrategy": "FULL" }],
      "Catch": [{ "ErrorEquals": ["States.ALL"], "ResultPath": "$.error", "Next": "HandleFailure" }]
    },

    "ResolveClaims": {
      "Type": "Task",
      "Resource": "arn:aws-us-gov:lambda:us-gov-east-1:008368474482:function:builting-resolve",
      "Parameters": {
        "claimsS3Key.$": "$.specResult.claimsS3Key",
        "userId.$": "$.userId",
        "renderId.$": "$.renderId",
        "bucket.$": "$.bucket",
        "renderRevision.$": "$.metadata.render.render_revision"
      },
      "ResultPath": "$.resolveResult",
      "Next": "TopologyEngine",
      "Retry": [{ "ErrorEquals": ["States.ALL"], "IntervalSeconds": 2, "MaxAttempts": 2, "BackoffRate": 2, "MaxDelaySeconds": 30, "JitterStrategy": "FULL" }],
      "Catch": [{ "ErrorEquals": ["States.ALL"], "ResultPath": "$.error", "Next": "HandleFailure" }]
    },

    "TopologyEngine": {
      "Type": "Task",
      "Resource": "arn:aws-us-gov:lambda:us-gov-east-1:008368474482:function:builting-topology-engine",
      "Parameters": {
        "cssS3Key.$": "$.specResult.cssS3Key",
        "userId.$": "$.userId",
        "renderId.$": "$.renderId",
        "bucket.$": "$.bucket",
        "renderRevision.$": "$.metadata.render.render_revision",
        "previousValidationReportS3Key.$": "$.metadata.render.validationReportS3Key"
      },
      "ResultPath": "$.topologyResult",
      "Next": "GenerateIFC",
      "Retry": [{ "ErrorEquals": ["States.ALL"], "IntervalSeconds": 5, "MaxAttempts": 2, "BackoffRate": 2, "MaxDelaySeconds": 60, "JitterStrategy": "FULL" }],
      "Catch": [{ "ErrorEquals": ["States.ALL"], "ResultPath": "$.error", "Next": "HandleFailure" }]
    },

    "GenerateIFC": {
      "Type": "Task",
      "Resource": "arn:aws-us-gov:lambda:us-gov-east-1:008368474482:function:builting-generate",
      "Parameters": {
        "cssS3Key.$": "$.topologyResult.cssS3Key",
        "bucket.$": "$.bucket",
        "renderId.$": "$.renderId",
        "userId.$": "$.userId"
      },
      "ResultPath": "$.ifcResult",
      "Next": "StoreIFC",
      "Retry": [{ "ErrorEquals": ["States.ALL"], "IntervalSeconds": 5, "MaxAttempts": 2, "BackoffRate": 2, "MaxDelaySeconds": 60, "JitterStrategy": "FULL" }],
      "Catch": [{ "ErrorEquals": ["States.ALL"], "ResultPath": "$.error", "Next": "HandleFailure" }]
    },

    "StoreIFC": {
      "Type": "Task",
      "Resource": "arn:aws-us-gov:lambda:us-gov-east-1:008368474482:function:builting-store",
      "Parameters": {
        "renderId.$": "$.renderId",
        "userId.$": "$.userId",
        "bucket.$": "$.bucket",
        "ifcS3Path.$": "$.ifcResult.ifcS3Path",
        "ai_generated_title.$": "$.specResult.ai_generated_title",
        "ai_generated_description.$": "$.specResult.ai_generated_description",
        "elementCounts.$": "$.ifcResult.elementCounts",
        "outputMode.$": "$.ifcResult.outputMode",
        "cssHash.$": "$.ifcResult.cssHash",
        "tracingReport.$": "$.specResult.tracingReport",
        "validationSummary.$": "$.ifcResult.validationSummary",
        "sourceFusion.$": "$.ifcResult.sourceFusion",
        "structuralWarnings.$": "$.ifcResult.structuralWarnings",
        "renderRevision.$": "$.metadata.render.render_revision",
        "refinementReport.$": "$.specResult.refinementReport",
        "refinementReportS3Key.$": "$.specResult.refinementReportS3Key",
        "readinessScore.$": "$.topologyResult.readinessScore",
        "exportReadiness.$": "$.topologyResult.exportReadiness",
        "authoringSuitability.$": "$.topologyResult.authoringSuitability",
        "criticalIssueCount.$": "$.topologyResult.criticalIssueCount",
        "validationWarningCount.$": "$.topologyResult.warningCount",
        "validationProxyRatio.$": "$.topologyResult.proxyRatio",
        "validationReportS3Key.$": "$.topologyResult.validationReportS3Key",
        "generationModeRecommendation.$": "$.topologyResult.generationModeRecommendation",
        "readinessDelta.$": "$.topologyResult.readinessDelta",
        "geometryFidelity.$": "$.topologyResult.geometryFidelity",
        "exportFormats.$": "$.ifcResult.exportFormats",
        "exportFiles.$": "$.ifcResult.exportFiles"
      },
      "Next": "SeedSensors",
      "Retry": [{ "ErrorEquals": ["States.ALL"], "IntervalSeconds": 2, "MaxAttempts": 2, "BackoffRate": 2, "MaxDelaySeconds": 30, "JitterStrategy": "FULL" }]
    },

    "SeedSensors": {
      "Type": "Task",
      "Resource": "arn:aws-us-gov:lambda:us-gov-east-1:008368474482:function:builting-sensors",
      "Parameters": {
        "renderId.$": "$.renderId",
        "userId.$": "$.userId",
        "elementCounts.$": "$.ifcResult.elementCounts"
      },
      "ResultPath": "$.sensorResult",
      "End": true,
      "Retry": [{ "ErrorEquals": ["States.ALL"], "IntervalSeconds": 2, "MaxAttempts": 1, "BackoffRate": 2, "MaxDelaySeconds": 30, "JitterStrategy": "FULL" }],
      "Catch": [{ "ErrorEquals": ["States.ALL"], "ResultPath": "$.sensorError", "Next": "SensorSeedFailed" }]
    },

    "SensorSeedFailed": {
      "Type": "Pass",
      "Comment": "Non-critical: sensor seeding failed but render is already complete",
      "End": true
    },

    "HandleFailure": {
      "Type": "Task",
      "Resource": "arn:aws-us-gov:lambda:us-gov-east-1:008368474482:function:builting-store",
      "Parameters": {
        "failureMode": true,
        "renderId.$": "$.renderId",
        "userId.$": "$.userId",
        "error.$": "$.error"
      },
      "End": true,
      "Retry": [{ "ErrorEquals": ["States.ALL"], "IntervalSeconds": 2, "MaxAttempts": 2, "BackoffRate": 2, "MaxDelaySeconds": 30, "JitterStrategy": "FULL" }]
    }
  }
}
