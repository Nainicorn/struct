{{#if main}}
<div class="__details-body">
  <div class="__details-title-section">
    <h2 class="__details-title"></h2>
  </div>

  <div class="__details-section">
    <h3 class="__details-section-title">Description</h3>
    <p class="__details-description"></p>
  </div>

  <div class="__details-section">
    <h3 class="__details-section-title">Source Files</h3>
    <div class="__details-files"></div>
  </div>

  <div class="__details-actions">
    <button class="__details-delete" title="Delete this render">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
      </svg>
    </button>
  </div>
</div>
{{/if}}
