{{#if main}}
<button class="__details-close" title="Close details">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
</button>
<div class="__details-body">
  <div class="__details-title-section">
    <h2 class="__details-title"></h2>
  </div>

  <div class="__details-section">
    <h3 class="__details-section-title">Description</h3>
    <p class="__details-description"></p>
  </div>

  <div class="__details-section">
    <h3 class="__details-section-title">Source Files</h3>
    <div class="__details-files"></div>
  </div>

  <div class="__details-section __details-refinement hidden">
    <h3 class="__details-section-title">Refinement</h3>
    <div class="__details-refinement-content"></div>
  </div>

  <div class="__details-section __details-quality hidden">
    <h3 class="__details-section-title">Model Quality</h3>
    <div class="__details-quality-content"></div>
  </div>

  <div class="__details-section __details-validation hidden">
    <h3 class="__details-section-title">Validation</h3>
    <div class="__details-validation-content"></div>
  </div>

  <div class="__details-section __details-stats hidden">
    <h3 class="__details-section-title">Model Statistics</h3>
    <div class="__details-stats-content"></div>
    <div class="__details-export-formats hidden">
      <span class="__details-export-label">Export Formats</span>
      <div class="__details-export-badges"></div>
    </div>
  </div>

  <div class="__details-section __details-traceability hidden">
    <h3 class="__details-section-title">Source Contributions</h3>
    <div class="__details-traceability-content"></div>
  </div>

  <div class="__details-section __details-structural hidden">
    <h3 class="__details-section-title">Structural Notes</h3>
    <div class="__details-structural-content"></div>
  </div>

  <div class="__details-section __details-warnings hidden">
    <h3 class="__details-section-title">Generation Notes</h3>
    <div class="__details-warnings-content"></div>
  </div>

  <div class="__details-section __details-omitted hidden">
    <h3 class="__details-section-title">Unmodeled Findings</h3>
    <div class="__details-omitted-content"></div>
  </div>

  <div class="__details-section __details-sensors hidden">
    <h3 class="__details-section-title">Live Telemetry</h3>
    <div class="__details-sensors-content"></div>
  </div>

  <div class="__details-actions">
    <button class="__details-download-report hidden" title="Download verification report">Download Report</button>
    <button class="__details-delete" title="Delete this render">Delete Render</button>
  </div>
</div>
{{/if}}
